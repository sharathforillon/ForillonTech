# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Analytics & Tracking
# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# LinkedIn Insight Tag Partner ID (for page view tracking)
VITE_LINKEDIN_PARTNER_ID=123456

# LinkedIn Conversion ID (optional, for conversion tracking)
# To get this: Campaign Manager → Analyze → Conversion Tracking → Create Conversion
# Then copy the numeric ID from the conversion rule
VITE_LINKEDIN_CONVERSION_ID=123456789

# Meta (Facebook) Pixel ID
VITE_META_PIXEL_ID=123456789012345

# CRM & Webhooks
HUBSPOT_API_KEY=your_hubspot_api_key_here
WEBHOOK_URL=https://your-webhook-endpoint.com/leads
WEBHOOK_SECRET=your_secret_for_hmac_signing

# Email Services
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
MAILERSEND_API_TOKEN=your_mailersend_token_here
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password

# Calendly
CALENDLY_LINK=https://calendly.com/your-org/meeting

# Optional: Database for Lead Storage
MONGODB_URI=mongodb://localhost:27017/checkbox_leads

# Heatmap & Session Recording (Optional)
VITE_HOTJAR_ID=123456
VITE_CLARITY_ID=abcd1234
